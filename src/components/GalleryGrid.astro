---

<section class="bento-grid">
  <article class="feature">
    <img src={projects[0].image} alt={projects[0].title} />
    <div class="overlay">
      <span>{projects[0].type}</span>
      <h3>{projects[0].title}</h3>
    </div>
  </article>

  <div class="process">
    <span>Method</span>
    <h2>Our Process</h2>
    <p>We review structure, materials, drainage, access, and finish details before the build starts.</p>
  </div>

  {projects.slice(1).map((project) => (
    <article class="card">
      <img src={project.image} alt={project.title} />
      <div class="overlay">
        <span>{project.type}</span>
        <h3>{project.title}</h3>
      </div>
    </article>
  ))}
</section>

<style>
.bento-grid {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  gap: 12px;
  margin-top: 40px;
}

.feature,
.process,
.card {
  position: relative;
  overflow: hidden;
  border: 1px solid var(--border);
}

.feature {
  grid-column: span 8;
  min-height: 440px;
}

.process {
  grid-column: span 4;
  background: var(--primary);
  color: white;
  padding: 32px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.process span,
.overlay span {
  color: #ffb690;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  font-size: 12px;
  font-weight: 700;
}

.process h2 {
  color: white;
  margin: 12px 0;
}

.process p {
  color: rgba(255,255,255,0.78);
}

.card {
  grid-column: span 6;
  min-height: 300px;
}

.feature img,
.card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 600ms ease;
}

.feature:hover img,
.card:hover img {
  transform: scale(1.05);
}

.overlay {
  position: absolute;
  inset: auto 0 0 0;
  padding: 24px;
  color: white;
  background: linear-gradient(to top, rgba(0,0,0,0.84), transparent);
}

.overlay h3 {
  margin: 8px 0 0;
  color: white;
}

@media (max-width: 768px) {
  .bento-grid {
    grid-template-columns: 1fr;
  }

  .feature,
  .process,
  .card {
    grid-column: span 1;
    min-height: 280px;
  }
}
</style>