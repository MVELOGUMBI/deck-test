  },
  {
    title: "Ipe Pool Deck - Hinsdale",
    type: "Ipe Wood",
    image: "https://lh3.googleusercontent.com/aida-public/AB6AXuCNxOQUZuwAh3nFjSgsVHNPTK4w6LWYYHJG_0F3KSEKOGKFVFYByNkiH1IoR8EPlPE4EwhzWFmtl0K1Epnfj_l6FKYclvC2e9NztFAcrKpLy2JaeQ-7TnGwo_NgLnInSYmXFDIshIiqyMVa_-fFlAdqSE5E6Z5PYNjbnaNXASY4GBVzYcUKdpL0YOBZqnBbLKeG53DJf2Fy2WNh1QqTWyaDHV7CY63c-Ot1zoAHH9eYLX8FiQXIBN6IKuzVHUdWMysjflFFTEzDL7dF"
