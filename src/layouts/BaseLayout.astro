---
const { title = "Deck Test" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@600;700;800;900&family=Work+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg: #faf9f7;
    --text: #1a1c1b;
    --muted: #434843;
    --primary: #061b0e;
    --secondary: #8f4d26;
    --border: #c3c8c1;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: "Work Sans", sans-serif;
  }

  h1,
  h2,
  h3 {
    font-family: "Inter", sans-serif;
    letter-spacing: -0.02em;
  }

  h1 {
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1;
    color: var(--primary);
  }

  h2 {
    font-size: clamp(28px, 4vw, 44px);
  }

  p {
    color: var(--muted);
    line-height: 1.6;
  }

  a,
  button {
    font-family: "Work Sans", sans-serif;
  }
</style>